# 阿里云百炼 ASR（Paraformer 实时语音识别）
DASHSCOPE_API_KEY=sk-your-dashscope-key

# Qwen LLM（阿里云百炼 DashScope 兼容模式，与 ASR 共用 DASHSCOPE_API_KEY）
# 文本模型: qwen3.7-plus / qwen-plus / qwen-max
# 视觉模型: qwen3-vl-plus / qwen3-vl-max（由 VISUAL_MODEL 控制）
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.7-plus
VISUAL_MODEL=qwen3-vl-plus
